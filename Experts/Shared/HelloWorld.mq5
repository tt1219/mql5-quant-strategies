#property copyright   "Copyright 2026, Your Name" // 著作権情報のプロパティ設定です。
#property link        "https://www.mql5.com"      // リンク先のURLを設定します。
#property version     "1.00"                      // プログラムのバージョン情報です。
#property strict                                  // より厳密なエラーチェックを行うための宣言です。

//+------------------------------------------------------------------+
//| 初期化関数 (OnInit)                                                |
//| EAがチャートに適用された時、最初に1回だけ実行されます。                    |
//+------------------------------------------------------------------+
int OnInit()
  {
   // _Symbolは、現在EAが適用されているチャートの通貨ペア名を取得する変数です。
   // Print関数は、ターミナルウィンドウの「エキスパート」タブに文字を出力します。
   Print("EA起動成功：", _Symbol);
   
   // 初期化処理が正常に完了したことを表す「INIT_SUCCEEDED」をシステムに返します。
   return(INIT_SUCCEEDED);
  }

//+------------------------------------------------------------------+
//| 終了処理関数 (OnDeinit)                                            |
//| EAがチャートから削除される時や、時間足の変更、MT5終了時などに実行されます。|
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
  {
   // エキスパートタブに、EAが正常に停止したことをログとして出力します。
   Print("EAを正常に停止しました");
   
   // チャート左上に表示していたコメントを空文字("")で上書きし、画面から消去します。
   Comment("");
  }

//+------------------------------------------------------------------+
//| ティック更新関数 (OnTick)                                          |
//| 価格（ティック）が新しく更新・配信されるたびに毎回実行されます。           |
//+------------------------------------------------------------------+
void OnTick()
  {
   // TimeCurrent()関数は、証券会社（ブローカー）の現在のサーバー時間を取得します。
   datetime currentTime = TimeCurrent();
   
   // SymbolInfoDouble関数を使用して、現在の通貨ペア(_Symbol)の最新の売値(Bid)を取得します。
   double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Comment関数を使用して、チャートの左上にテキストを常時表示します。
   // "\n" は改行を意味します。サーバー時間とBid価格を2行に分けて表示します。
   Comment("サーバー時間：", currentTime, "\n", "最新のBid価格：", currentBid);
  }
//+------------------------------------------------------------------+
