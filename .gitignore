# MQL5 Project Ignore Rules

# MT5 Standard Folders (Ignore)
Include/
!Include/AppCore/
Libraries/
Experts/Examples/
Experts/Advisors/
Experts/Free Robots/
Scripts/Examples/
Scripts/UnitTests/
Indicators/Examples/

# Compiled binaries
*.ex5
*.ex4

# Logs and temporary files
Logs/
Tester/
temp/
MQL5/Logs/
MQL5/Tester/

# Environment specific data
experts.dat
*.ini
*.opt

# OS specific files
.DS_Store
Thumbs.db

# MT5 Chart Profiles (Local Workspace State)
Profiles/**/*.chr

# Backtest results and raw data
**/data/
**/BacktestResults_Opt/
*.csv
*.html
!**/reports/*.md
!**/reports/*.html

# Knowledge items for AI agents (Optional: keep if you want to track them)
#!.agents/
